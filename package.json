    "styled-jsx": "^5.1.7",
    "svg-react-loader": "^0.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tinacms": "3.7.5",
    "tw-animate-css": "^1.4.0",
    "unplugin-info": "^1.3.2",
    "usehooks-ts": "^3.1.1"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
