    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "fontawesome": "^5.6.3",
    "gray-matter": "^4.0.3",
    "instantsearch.js": "^4.96.0",
    "lucide-react": "^0.484.0",
    "mermaid": "^11.14.0",
    "moment": "^2.30.1",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "prop-types": "^15.8.1",
